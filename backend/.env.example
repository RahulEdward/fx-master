# ============================================================
# FX-Master Environment Configuration
# ============================================================

# --- Application ---
APP_NAME=FX-Master
APP_ENV=development
DEBUG=true
SECRET_KEY=your-super-secret-key-change-in-production
API_PREFIX=/api/v1

# --- Database (PostgreSQL) ---
DATABASE_URL=postgresql+asyncpg://fxmaster:fxmaster_pass@localhost:5432/fxmaster_db

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- JWT Auth ---
JWT_SECRET_KEY=your-jwt-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# --- Encryption Key (for broker API tokens) ---
ENCRYPTION_KEY=your-fernet-encryption-key-base64

# --- OANDA Broker ---
# Users provide their own tokens via the API, but these are defaults for testing
OANDA_DEMO_URL=https://api-fxpractice.oanda.com
OANDA_LIVE_URL=https://api-fxtrade.oanda.com
OANDA_STREAM_DEMO_URL=https://stream-fxpractice.oanda.com
OANDA_STREAM_LIVE_URL=https://stream-fxtrade.oanda.com

# --- CORS ---
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# --- Rate Limiting ---
RATE_LIMIT_PER_MINUTE=120
